<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://xml.sandglass.org/fxml/1" fx:controller="edu.ijse.fx.orm.controller.ProgramController">
    <children>
        <VBox layoutX="30.0" layoutY="25.0" spacing="12.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="25.0">
            <children>
                <Label text="Program Management" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>

                <HBox spacing="15.0">
                    <children>
                        <VBox HBox.hgrow="ALWAYS" spacing="4.0">
                            <children>
                                <Label text="Program ID :" />
                                <TextField fx:id="txtProgramId" prefHeight="30.0" promptText="Enter Program ID" />
                            </children>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="4.0">
                            <children>
                                <Label text="Program Name :" />
                                <TextField fx:id="txtProgramName" prefHeight="30.0" promptText="Enter Program Name" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <Button fx:id="btnSave" mnemonicParsing="false" onAction="#btnSaveOnAction" prefHeight="35.0" prefWidth="80.0" style="-fx-background-color: #2ecc71;" text="Save" textFill="WHITE"><font><Font name="System Bold" size="13.0" /></font></Button>
                        <Button fx:id="btnUpdate" mnemonicParsing="false" onAction="#btnUpdateOnAction" prefHeight="35.0" prefWidth="80.0" style="-fx-background-color: #3498db;" text="Update" textFill="WHITE"><font><Font name="System Bold" size="13.0" /></font></Button>
                        <Button fx:id="btnDelete" mnemonicParsing="false" onAction="#btnDeleteOnAction" prefHeight="35.0" prefWidth="80.0" style="-fx-background-color: #e74c3c;" text="Delete" textFill="WHITE"><font><Font name="System Bold" size="13.0" /></font></Button>
                        <Button fx:id="btnClear" mnemonicParsing="false" onAction="#btnClearOnAction" prefHeight="35.0" prefWidth="80.0" style="-fx-background-color: #95a5a6;" text="Clear" textFill="WHITE"><font><Font name="System Bold" size="13.0" /></font></Button>
                    </children>
                    <VBox.margin><Insets bottom="5.0" top="5.0" /></VBox.margin>
                </HBox>

                <TableView fx:id="tblProgram" prefHeight="280.0" prefWidth="540.0">
                    <columns>
                        <TableColumn fx:id="colProgramId" prefWidth="180.0" text="Program ID" />
                        <TableColumn fx:id="colProgramName" prefWidth="358.0" text="Program Name" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>